@page
@model VideoModel
@{
    ViewData["Title"] = "VIDEO_GEN";
}

<section class="gen">
    <div class="gen-head">
        <div class="gen-crumbs">/ <a asp-page="/Index">HOME</a> / <span class="hl">VIDEO_GEN</span></div>
        <h1 class="gen-title glitch" data-text="VIDEO_SYNTH">VIDEO_SYNTH</h1>
        <p class="gen-lede">frames in motion. lock a style, iterate forward, keep the chaos coherent.</p>
    </div>

    <div class="gen-grid">
        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag">01</span>
                <span class="panel-name">// THEME</span>
                <span class="panel-hint">choose one</span>
            </div>
            <div class="chip-grid" data-group="theme" data-dynamic="true"></div>
        </div>

        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag">02</span>
                <span class="panel-name">// MOTION</span>
                <span class="panel-hint">how it moves</span>
            </div>
            <div class="chip-grid" data-group="motion" data-dynamic="true"></div>
        </div>

        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag">03</span>
                <span class="panel-name">// MOOD</span>
                <span class="panel-hint">energy curve</span>
            </div>
            <div class="chip-grid" data-group="mood" data-dynamic="true"></div>
        </div>

        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag">04</span>
                <span class="panel-name">// DURATION</span>
                <span class="panel-hint">seconds of chaos</span>
            </div>
            <div class="chip-grid" data-group="duration">
                <button class="chip" data-value="2">02s</button>
                <button class="chip" data-value="4">04s</button>
                <button class="chip" data-value="8">08s</button>
                <button class="chip" data-value="12">12s</button>
            </div>
        </div>

        <div class="gen-panel gen-panel--wide">
            <div class="panel-bar">
                <span class="panel-tag">05</span>
                <span class="panel-name">// SEED_FRAME</span>
                <span class="panel-hint">optional. continuity anchor.</span>
            </div>
            <label class="dropzone" for="refUpload">
                <input id="refUpload" type="file" accept="image/*" hidden>
                <div class="dropzone-inner">
                    <div class="drop-cross">+</div>
                    <div class="drop-text">DRAG &middot; CLICK &middot; PASTE</div>
                    <div class="drop-sub" id="dropSub">no seed frame</div>
                </div>
            </label>
        </div>

        <div class="gen-panel gen-panel--wide">
            <div class="panel-bar">
                <span class="panel-tag">06</span>
                <span class="panel-name">// DIRECTOR_NOTES</span>
                <span class="panel-hint">optional. one line of intent.</span>
            </div>
            <textarea class="director" placeholder="> figure walks toward camera as the room dissolves..."></textarea>
        </div>
    </div>

    <div class="gen-foot">
        <div class="prompt-readout">
            <span class="readout-label">// ASSEMBLED_SIGNAL</span>
            <div class="readout-body" id="promptReadout">— awaiting input —</div>
        </div>
        <button class="generate" id="generateBtn">
            <span class="gen-label">RENDER</span>
            <span class="gen-arrow">»</span>
        </button>
    </div>
</section>
