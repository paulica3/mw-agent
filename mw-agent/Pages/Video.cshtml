@page
@model VideoModel
@{
    ViewData["Title"] = "VIDEO_GEN";
}

<section class="gen">
    <div class="gen-head">
        <div class="gen-crumbs">/ <a asp-page="/Index">HOME</a> / <span class="hl">VIDEO_GEN</span></div>
        <h1 class="gen-title glitch" data-text="VIDEO_SYNTH">VIDEO_SYNTH</h1>
        <p class="gen-lede">frames in motion. lock a style, iterate forward, keep the chaos coherent.</p>
    </div>

    <div class="gen-grid">
        <!-- panels rendered by JS from the chip store, filtered to showOn:video -->
        <div id="dynamicPanels" class="contents"></div>

        <!-- static panels: duration (numeric), dropzone, notes -->
        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag"></span>
                <span class="panel-name">// DURATION</span>
                <span class="panel-hint">seconds of chaos</span>
            </div>
            <div class="chip-grid" data-group="duration">
                <button class="chip" data-value="5">05s</button>
                <button class="chip" data-value="10">10s</button>
            </div>
        </div>

        <div class="gen-panel">
            <div class="panel-bar">
                <span class="panel-tag"></span>
                <span class="panel-name">// QUALITY</span>
                <span class="panel-hint">render performance tier</span>
            </div>
            <div class="chip-grid" data-group="quality">
                <button class="chip chip--cost" data-value="draft">DRAFT<span class="chip-cost">fast</span></button>
                <button class="chip chip--cost" data-value="standard">STANDARD<span class="chip-cost">balanced</span></button>
                <button class="chip chip--cost" data-value="pro">PRO<span class="chip-cost">sharp</span></button>
                <button class="chip chip--cost" data-value="master">MASTER<span class="chip-cost">premium</span></button>
            </div>
        </div>

        <div class="gen-panel gen-panel--wide">
            <div class="panel-bar">
                <span class="panel-tag"></span>
                <span class="panel-name">// SEED_FRAME</span>
                <span class="panel-hint">optional. continuity anchor.</span>
            </div>
            <label class="dropzone" for="refUpload">
                <input id="refUpload" type="file" accept="image/*,video/*" hidden>
                <div class="dropzone-inner">
                    <div class="drop-cross">+</div>
                    <div class="drop-text">DRAG &middot; CLICK &middot; PASTE</div>
                    <div class="drop-sub" id="dropSub">image or video for reference</div>
                </div>
            </label>
        </div>

        <div class="gen-panel gen-panel--wide">
            <div class="panel-bar">
                <span class="panel-tag"></span>
                <span class="panel-name">// AUDIO_SYNC</span>
                <span class="panel-hint">optional. analyze a track for tempo + energy.</span>
            </div>
            <label class="dropzone dropzone--audio" for="audioUpload">
                <input id="audioUpload" type="file" accept="audio/*" hidden>
                <div class="dropzone-inner">
                    <div class="drop-cross">♪</div>
                    <div class="drop-text">DROP &middot; AUDIO</div>
                    <div class="drop-sub" id="audioSub">no audio loaded</div>
                </div>
            </label>
            <div class="audio-readout" id="audioReadout" hidden>
                <span class="audio-stat"><span class="audio-stat-label">bpm</span><span class="audio-stat-val" id="audioBpm">—</span></span>
                <span class="audio-stat"><span class="audio-stat-label">duration</span><span class="audio-stat-val" id="audioDur">—</span></span>
                <span class="audio-stat"><span class="audio-stat-label">energy</span><span class="audio-stat-val" id="audioEnergy">—</span></span>
                <button class="audio-clear" id="audioClear" type="button">clear</button>
            </div>
        </div>

        <div class="gen-panel gen-panel--wide">
            <div class="panel-bar">
                <span class="panel-tag"></span>
                <span class="panel-name">// DIRECTOR_NOTES</span>
                <span class="panel-hint">optional. one line of intent.</span>
            </div>
            <textarea class="director" placeholder="> figure walks toward camera as the room dissolves..."></textarea>
        </div>
    </div>

    <div class="gen-foot">
        <div class="prompt-readout">
            <div class="readout-head">
                <span class="readout-label">// ASSEMBLED_SIGNAL</span>
                <button class="readout-enhance" id="readoutEnhance" type="button" title="Rewrite the prompt with AI">✦ enhance</button>
                <button class="readout-reset" id="readoutReset" type="button" hidden>↺ reset to auto</button>
            </div>
            <div class="readout-body is-empty" id="promptReadout"
                 contenteditable="plaintext-only" spellcheck="false"
                 data-placeholder="— awaiting input · click to edit —"></div>
        </div>
        <div class="preset-bar" id="presetBar">
            <span class="preset-label">// PRESETS</span>
            <div class="preset-list" id="presetList"></div>
            <button class="preset-save" id="presetSave" type="button">+ save current</button>
        </div>
        <button class="generate" id="generateBtn">
            <span class="gen-label">RENDER</span>
            <span class="gen-arrow">»</span>
        </button>
    </div>
</section>
