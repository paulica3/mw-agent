@page
@model DashboardModel
@{
    ViewData["Title"] = "DASHBOARD";
}

<section class="gen dashboard">
    <div class="gen-head">
        <div class="gen-crumbs">/ <a asp-page="/Index">HOME</a> / <span class="hl">DASHBOARD</span></div>
        <h1 class="gen-title glitch" data-text="CUSTOMIZE_SIGNAL">CUSTOMIZE_SIGNAL</h1>
        <p class="gen-lede">edit any chip. delete what you don't use. add new categories on the fly.</p>
        <div class="dash-status-row">
            <span class="dash-status" id="dashStatus">connecting…</span>
            <button class="dash-reset-all" type="button" id="dashResetAll">reset everything</button>
        </div>
    </div>

    <form class="dash-new-cat gen-panel" id="dashNewCategory">
        <div class="panel-bar">
            <span class="panel-tag">+</span>
            <span class="panel-name">// ADD_NEW_CATEGORY</span>
            <span class="panel-hint">a new panel of chips on image / video</span>
        </div>
        <div class="dash-new-cat-row">
            <input name="label" type="text" placeholder="CATEGORY NAME  (e.g. LIGHTING)" maxlength="32" required/>
            <input name="hint"  type="text" placeholder="hint text  (e.g. light direction)" maxlength="40"/>
            <div class="dash-new-cat-toggles">
                <label class="dash-toggle">
                    <input type="checkbox" name="image" checked/>
                    <span>image</span>
                </label>
                <label class="dash-toggle">
                    <input type="checkbox" name="video" checked/>
                    <span>video</span>
                </label>
            </div>
            <button class="dash-add-btn dash-new-cat-btn" type="submit"><span>+ create category</span></button>
        </div>
    </form>

    <div class="dash-grid" id="dashGrid">
        <div class="dash-empty">— loading… —</div>
    </div>

    <div class="dash-footer">
        <span class="dash-foot-note">// synced to your account via vercel kv · changes save automatically</span>
    </div>
</section>
