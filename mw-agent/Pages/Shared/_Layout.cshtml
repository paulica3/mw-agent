@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var bodyClass = page.Replace("/", "").ToLowerInvariant();

    var theme = Context.Request.Cookies["xa-theme"];
    if (theme != "bloom" && theme != "chaos") theme = "chaos";
    var themeColor = theme == "bloom" ? "#f1e9da" : "#050505";
}
<!DOCTYPE html>
<html lang="en" data-theme="@theme">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
    <meta name="theme-color" content="@themeColor" id="themeColorMeta"/>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true"/>
    <link rel="alternate icon" href="~/favicon.svg"/>
    <link rel="apple-touch-icon" href="~/favicon.svg"/>
    <title>@ViewData["Title"] // XPERIMENT_AI</title>
    <script>
        // belt-and-suspenders: if cookie missing but localStorage has theme, sync it
        (function(){
            try {
                var stored = localStorage.getItem('xa-theme');
                var current = document.documentElement.getAttribute('data-theme');
                if (stored && stored !== current && (stored === 'bloom' || stored === 'chaos')) {
                    document.documentElement.setAttribute('data-theme', stored);
                    document.cookie = 'xa-theme=' + stored + '; path=/; max-age=31536000; samesite=lax';
                }
            } catch(e) {}
        })();
        // auth gate — synchronous redirect before render so no flash of protected content.
        // login page itself is exempt; everything else requires xa-token in localStorage.
        (function(){
            try {
                var path = location.pathname.toLowerCase();
                var isLogin = path.indexOf('login') !== -1;
                var hasToken = !!localStorage.getItem('xa-token');
                if (!isLogin && !hasToken) {
                    var from = encodeURIComponent(location.pathname + location.search);
                    location.replace('/login?from=' + from);
                }
            } catch(e) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&family=Press+Start+2P&family=Italianno&family=Pinyon+Script&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="page-@bodyClass">

<div class="fx-layer fx-grid"></div>
<canvas id="fx-noise" class="fx-layer fx-noise"></canvas>
<div class="fx-layer fx-scanlines"></div>
<div class="fx-layer fx-vignette"></div>
<div class="fx-layer fx-orbs">
    <span class="orb orb-1"></span>
    <span class="orb orb-2"></span>
    <span class="orb orb-3"></span>
    <span class="orb orb-4"></span>
</div>

<canvas id="sparkle-trail" class="sparkle-trail"></canvas>
<div class="cursor-star" id="cursorStar">
    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 0 L17.8 14.2 L32 16 L17.8 17.8 L16 32 L14.2 17.8 L0 16 L14.2 14.2 Z" fill="white"/>
        <path d="M16 6 L16.9 14.8 L26 16 L16.9 17.2 L16 26 L15.1 17.2 L6 16 L15.1 14.8 Z" fill="rgba(0,0,0,0.5)"/>
    </svg>
</div>

<header class="nav">
    <a class="nav-brand glitch" data-text="XPERIMENT_AI" asp-page="/Index">
        <span>XPERIMENT</span><span class="nav-brand-accent">_AI</span>
    </a>
    <nav class="nav-links">
        <a asp-page="/Index" class="nav-link">[ HOME ]</a>
        <a asp-page="/Image" class="nav-link">[ IMAGE ]</a>
        <a asp-page="/Video" class="nav-link">[ VIDEO ]</a>
        <a asp-page="/Dashboard" class="nav-link">[ DASH ]</a>
        <a asp-page="/Subscription" class="nav-link">[ PLAN ]</a>
    </nav>
    <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle theme" title="Switch mood">
            <span class="toggle-label toggle-label--left">CHAOS</span>
            <span class="toggle-track">
                <span class="toggle-thumb">
                    <span class="toggle-icon toggle-icon--star">✦</span>
                    <span class="toggle-icon toggle-icon--bloom">✿</span>
                </span>
            </span>
            <span class="toggle-label toggle-label--right">bloom</span>
        </button>
        <div class="nav-status">
            <span class="status-dot"></span>
            <span class="status-text" id="navClock">SYS.ONLINE</span>
        </div>
        <button class="nav-logout" id="navLogout" type="button" title="Log out" aria-label="Log out">⏻</button>
    </div>
</header>

<main class="main">
    @RenderBody()
</main>

<!-- generation modal — opens when user hits GENERATE/RENDER on image/video pages -->
<div class="gen-modal" id="genModal" hidden>
    <div class="gen-modal-overlay" data-close-modal></div>
    <div class="gen-modal-card">
        <button class="gen-modal-close" type="button" data-close-modal aria-label="Close">×</button>

        <div class="gen-modal-pane" data-pane="loading">
            <div class="gen-modal-title glitch" data-text="RENDERING_SIGNAL">RENDERING_SIGNAL</div>
            <div class="gen-modal-spinner"><span></span><span></span><span></span><span></span></div>
            <div class="gen-modal-status" id="genModalStatus">// initializing pipeline...</div>
            <div class="gen-modal-meta">
                <span class="gen-modal-meta-row">elapsed: <span id="genModalTimer">00:00</span></span>
                <span class="gen-modal-meta-row" id="genModalEst">est: 60-120s</span>
            </div>
            <div class="gen-modal-prompt" id="genModalPrompt"></div>
        </div>

        <div class="gen-modal-pane" data-pane="success" hidden>
            <div class="gen-modal-title glitch" data-text="SIGNAL_COMPLETE">SIGNAL_COMPLETE</div>
            <div class="gen-modal-result" id="genModalResult"></div>
            <div class="gen-modal-actions">
                <a class="gen-modal-btn gen-modal-download" id="genModalDownload" download>download</a>
                <button class="gen-modal-btn gen-modal-secondary" type="button" data-close-modal>close</button>
            </div>
        </div>

        <div class="gen-modal-pane" data-pane="error" hidden>
            <div class="gen-modal-title">SIGNAL_LOST</div>
            <div class="gen-modal-error" id="genModalError">connection failure</div>
            <div class="gen-modal-actions">
                <button class="gen-modal-btn gen-modal-secondary" type="button" data-close-modal>close</button>
            </div>
        </div>

        <div class="gen-modal-pane" data-pane="comingSoon" hidden>
            <div class="gen-modal-title">NOT_YET_WIRED</div>
            <div class="gen-modal-coming">image generation is not connected to a backend yet.<br/>video generation works — try the video tab.</div>
            <div class="gen-modal-actions">
                <button class="gen-modal-btn gen-modal-secondary" type="button" data-close-modal>close</button>
            </div>
        </div>
    </div>
</div>

<footer class="footer">
    <div class="footer-row">
        <span class="footer-text footer-text--chaos">// XPERIMENT_AI v0.1</span>
        <span class="footer-text footer-text--bloom">xperiment.ai · made for the mood</span>
        <span class="footer-blink">█</span>
        <span class="footer-text footer-text--chaos">@DateTime.UtcNow.Year — ALL SIGNALS DISTORTED</span>
        <span class="footer-text footer-text--bloom">@DateTime.UtcNow.Year · stay soft</span>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
