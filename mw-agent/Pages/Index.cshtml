@page
@model IndexModel
@{
    ViewData["Title"] = "HOME";
}

<section class="hero">
    <div class="hero-meta">
        <span class="meta-tick">▌</span>
        <span>BOOT_SEQUENCE/COMPLETE</span>
        <span class="meta-sep">//</span>
        <span>OPERATOR: <em>UNKNOWN</em></span>
        <span class="meta-sep">//</span>
        <span class="meta-pulse">AWAITING_INPUT</span>
    </div>

    <h1 class="hero-title">
        <span class="hero-line glitch" data-text="XPERIMENT">XPERIMENT</span>
        <span class="hero-line hero-line--alt glitch glitch--slow" data-text="_AI">_AI</span>
    </h1>

    <p class="hero-sub">
        an engine for chaotic visuals.<br/>
        no prompts. no typing. just <span class="hl">signal</span>.
    </p>

    <div class="portals">
        <a asp-page="/Image" class="portal portal--image">
            <div class="portal-tag">[ 01 ]</div>
            <div class="portal-title glitch" data-text="IMAGE">IMAGE</div>
            <div class="portal-sub">single frame &middot; still chaos</div>
            <div class="portal-art portal-art--image">
                <span></span><span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
            <div class="portal-cta">ENTER &nbsp;»</div>
        </a>

        <a asp-page="/Video" class="portal portal--video">
            <div class="portal-tag">[ 02 ]</div>
            <div class="portal-title glitch" data-text="VIDEO">VIDEO</div>
            <div class="portal-sub">moving frames &middot; sequence chaos</div>
            <div class="portal-art portal-art--video">
                <div class="film">
                    <div class="film-strip"></div>
                    <div class="film-strip"></div>
                    <div class="film-strip"></div>
                </div>
            </div>
            <div class="portal-cta">ENTER &nbsp;»</div>
        </a>
    </div>

    <div class="ticker">
        <div class="ticker-track">
            <span>★ FUTURISTIC ★ SURREAL ★ GRITTY ★ DREAMLIKE ★ RETRO ★ NEON ★ MONOCHROME ★ DISTORTED ★ HOLOGRAPHIC ★ CINEMATIC ★ CHAOTIC ★</span>
            <span>★ FUTURISTIC ★ SURREAL ★ GRITTY ★ DREAMLIKE ★ RETRO ★ NEON ★ MONOCHROME ★ DISTORTED ★ HOLOGRAPHIC ★ CINEMATIC ★ CHAOTIC ★</span>
        </div>
    </div>
</section>
